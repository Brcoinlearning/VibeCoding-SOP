# Agent-in-Tool Standalone CLI 配置文件

# Anthropic API密钥 (必需)
ANTHROPIC_API_KEY=your-api-key-here

# 工作区路径 (可选，默认为当前目录)
WORKSPACE_PATH=.

# Git配置
GIT_AUTHOR_NAME=Agent-in-Tool Bot
GIT_AUTHOR_EMAIL=bot@example.com

# 审查模型 (可选)
REVIEW_MODEL=claude-3-7-sonnet-20250219

# API超时时间 (秒)
API_TIMEOUT=120

# 非交互模式 (用于CI/CD)
NON_INTERACTIVE=false
