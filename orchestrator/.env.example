# Orchestrator Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# 基础路径配置
# =============================================================================
ORCHESTRATOR_BASE_PATH=/Users/mr.hu/Desktop/开发项目/软件开发SOP/orchestrator
ORCHESTRATOR_WORKSPACE_PATH=/Users/mr.hu/Desktop/开发项目/软件开发SOP/orchestrator/workspace
ORCHESTRATOR_ARTIFACTS_PATH=/Users/mr.hu/Desktop/开发项目/软件开发SOP/orchestrator/artifacts
ORCHESTRATOR_LOGS_PATH=/Users/mr.hu/Desktop/开发项目/软件开发SOP/orchestrator/logs

# =============================================================================
# 目录结构配置
# =============================================================================
ORCHESTRATOR_PLANNING_DIR=20-planning
ORCHESTRATOR_BUILD_DIR=30-build
ORCHESTRATOR_REVIEW_DIR=40-review
ORCHESTRATOR_RELEASE_DIR=50-release

# =============================================================================
# 日志配置
# =============================================================================
ORCHESTRATOR_LOG_LEVEL=INFO
ORCHESTRATOR_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
ORCHESTRATOR_LOG_MAX_BYTES=10485760
ORCHESTRATOR_LOG_BACKUP_COUNT=5

# =============================================================================
# 事件处理配置
# =============================================================================
ORCHESTRATOR_ENABLE_EVENT_LOGGING=true
ORCHESTRATOR_EVENT_QUEUE_SIZE=1000
ORCHESTRATOR_EVENT_PROCESSING_TIMEOUT=300

# =============================================================================
# 证据收集配置
# =============================================================================
ORCHESTRATOR_MAX_DIFF_SIZE=50000
ORCHESTRATOR_MAX_LOG_LINES=1000
ORCHESTRATOR_EVIDENCE_FRESHNESS_THRESHOLD=3600

# =============================================================================
# AI 集成配置
# =============================================================================
# AI 后端类型：filesystem（文件系统） | claude-api（Claude API） | custom（自定义）
ORCHESTRATOR_AI_BACKEND=filesystem

# Claude API 配置（仅当 ai_backend=claude-api 时需要）
# ORCHESTRATOR_CLAUDE_API_KEY=your-api-key-here
ORCHESTRATOR_CLAUDE_MODEL=claude-3-opus-20240229
ORCHESTRATOR_AI_TIMEOUT=120

# =============================================================================
# MCP Server 配置
# =============================================================================
ORCHESTRATOR_MCP_TRANSPORT=stdio
ORCHESTRATOR_MCP_SERVER_NAME=sop-orchestrator

# 审查模式（mcp | cli）
ORCHESTRATOR_REVIEW_MODE=mcp

# =============================================================================
# Claude Code 集成
# =============================================================================
ORCHESTRATOR_CLAUDE_CODE_HOOK_ENABLED=true
# ORCHESTRATOR_CLAUDE_CODE_SESSION_ID=auto-generated

# =============================================================================
# 重试配置
# =============================================================================
ORCHESTRATOR_MAX_RETRIES=3
ORCHESTRATOR_RETRY_DELAY=5

# =============================================================================
# 回退配置
# =============================================================================
ORCHESTRATOR_AUTO_ROLLBACK_ENABLED=true
ORCHESTRATOR_ROLLBACK_ON_STALE_EVIDENCE=true
ORCHESTRATOR_ROLLBACK_ON_MISSING_INPUT=true
ORCHESTRATOR_ROLLBACK_ON_UNSTRUCTURED_OUTPUT=true

# =============================================================================
# 通知配置
# =============================================================================
ORCHESTRATOR_NOTIFICATION_ENABLED=true
ORCHESTRATOR_NOTIFICATION_METHOD=console
# ORCHESTRATOR_NOTIFICATION_WEBHOOK_URL=https://your-webhook-url

# =============================================================================
# 开发模式
# =============================================================================
ORCHESTRATOR_DEBUG_MODE=false
ORCHESTRATOR_MOCK_MODE=false
