# macOS
.DS_Store

# Local tool state
.claude/

# Python caches and virtual envs
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/venv/
**/*.egg-info/

# Environment files
**/.env
**/.env.*
!**/.env.example

# Runtime artifacts
orchestrator/artifacts/
orchestrator/logs/
orchestrator/archive/

# Accidental bootstrap literal path folder
orchestrator/$(pwd)/
